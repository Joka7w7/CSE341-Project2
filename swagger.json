{
  "swagger": "2.0",
  "info": {
    "title": "Library API",
    "description": "API for managing books and authors",
    "version": "1.0.0"
  },
  "host": "cse341-project2-473b.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "paths": {
    "/": {
      "get": {
        "tags": ["General"],
        "description": "Hello world route",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },

    "/books/": {
      "get": {
        "tags": ["Books"],
        "description": "Get all books",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "List of books"
          }
        }
      },
      "post": {
        "tags": ["Books"],
        "description": "Create a new book",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "title": { "example": "Clean Code" },
                "author": { "example": "Robert C. Martin" },
                "genre": { "example": "Programming" },
                "publishedYear": { "example": 2008 },
                "pages": { "example": 464 },
                "language": { "example": "English" },
                "publisher": { "example": "Prentice Hall" },
                "isbn": { "example": "978-0132350884" },
                "available": { "example": true }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Book created"
          },
          "400": {
            "description": "Invalid input"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },

    "/books/{id}": {
      "get": {
        "tags": ["Books"],
        "description": "Get a book by ID",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Book found"
          },
          "404": {
            "description": "Book not found"
          }
        }
      },
      "put": {
        "tags": ["Books"],
        "description": "Update a book",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "title": { "example": "Clean Code" },
                "author": { "example": "Robert C. Martin" },
                "genre": { "example": "Programming" },
                "publishedYear": { "example": 2008 },
                "pages": { "example": 464 },
                "language": { "example": "English" },
                "publisher": { "example": "Prentice Hall" },
                "isbn": { "example": "978-0132350884" },
                "available": { "example": true }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Book updated"
          },
          "400": {
            "description": "Invalid input"
          },
          "404": {
            "description": "Book not found"
          }
        }
      },
      "delete": {
        "tags": ["Books"],
        "description": "Delete a book",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Book deleted"
          },
          "404": {
            "description": "Book not found"
          }
        }
      }
    },

    "/authors/": {
      "get": {
        "tags": ["Authors"],
        "description": "Get all authors",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "List of authors"
          }
        }
      },
      "post": {
        "tags": ["Authors"],
        "description": "Create a new author",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "example": "James Clear" },
                "nationality": { "example": "American" },
                "birthYear": { "example": 1986 },
                "genre": { "example": "Self-help" },
                "notableWork": { "example": "Atomic Habits" },
                "awards": { "example": "Goodreads Choice Award" },
                "alive": { "example": true }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Author created"
          },
          "400": {
            "description": "Invalid input"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },

    "/authors/{id}": {
      "get": {
        "tags": ["Authors"],
        "description": "Get an author by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Author found"
          },
          "404": {
            "description": "Author not found"
          }
        }
      },
      "put": {
        "tags": ["Authors"],
        "description": "Update an author",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "example": "James Clear" },
                "nationality": { "example": "American" },
                "birthYear": { "example": 1986 },
                "genre": { "example": "Self-help" },
                "notableWork": { "example": "Atomic Habits" },
                "awards": { "example": "Goodreads Choice Award" },
                "alive": { "example": true }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Author updated"
          },
          "400": {
            "description": "Invalid input"
          },
          "404": {
            "description": "Author not found"
          }
        }
      },
      "delete": {
        "tags": ["Authors"],
        "description": "Delete an author",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Author deleted"
          },
          "404": {
            "description": "Author not found"
          }
        }
      }
    }
  }
}
